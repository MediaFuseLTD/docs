{
    "info": {
        "_postman_id": "a1b2c3d4-e5f6-7890-1234-56789abcdef0",
        "name": "MediaFuse External API",
        "description": "Postman Collection for the MediaFuse External API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Orders",
            "item": [
                {
                    "name": "Get Orders",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/orders?limit=50&offset=0&status=all",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "orders"
                            ],
                            "query": [
                                {
                                    "key": "limit",
                                    "value": "50",
                                    "description": "Max orders to return (1–200, default 50)"
                                },
                                {
                                    "key": "offset",
                                    "value": "0",
                                    "description": "Number of orders to skip"
                                },
                                {
                                    "key": "status",
                                    "value": "all",
                                    "description": "Filter by status: all | finished | processing"
                                }
                            ]
                        },
                        "description": "Retrieves a paginated list of your PR distribution orders. Response includes press_release_title, order_status, distribution_date_utc, created_at."
                    },
                    "response": []
                },
                {
                    "name": "Get Order Articles",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/orders/:id/articles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "orders",
                                ":id",
                                "articles"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "123",
                                    "description": "The order ID"
                                }
                            ]
                        },
                        "description": "Retrieves published articles for an order. Returns order_id, press_release_title, and data[] with article_url, published_at, website_domain."
                    },
                    "response": []
                }
            ]
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "cw_ext_your_api_key_here",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "https://app.chainwire.org/api/external-api/v1",
            "type": "string"
        }
    ]
}